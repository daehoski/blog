---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="ko">
<head>
  <BaseHead title="토익 RC 문법 정리 | 기초부터 완전 정복" description="토익 Part 5/6 필수 문법 10챕터 완전 정복. 품사, 시제, 수일치, 관계사, 접속사 등 실전 문제 포함." />
  <style>
    * { box-sizing: border-box; }
    body { background: #f5f5f7; }
    main { max-width: 900px; margin: 0 auto; padding: 5rem 1.5rem; }

    .page-header { text-align: center; margin-bottom: 3rem; }
    .badge { display: inline-block; padding: .35rem 1rem; background: linear-gradient(135deg,#30d158,#34c759); color: #fff; border-radius: 999px; font-size: .75rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; margin-bottom: 1rem; }
    .page-header h1 { font-size: clamp(1.8rem,5vw,2.8rem); font-weight: 800; color: #1d1d1f; letter-spacing: -.04em; margin-bottom: .75rem; }
    .page-header p { color: #86868b; font-size: 1rem; font-weight: 500; }

    /* 챕터 목록 */
    .chapter-list { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 3rem; }
    .chapter-item { background: #fff; border-radius: 20px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,.05); }
    .chapter-header { display: flex; align-items: center; gap: 1.25rem; padding: 1.5rem 2rem; cursor: pointer; transition: background .2s; user-select: none; }
    .chapter-header:hover { background: #f9f9fb; }
    .chapter-num { width: 2.2rem; height: 2.2rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: .8rem; font-weight: 800; color: #fff; flex-shrink: 0; }
    .chapter-info { flex: 1; }
    .chapter-info h2 { font-size: 1.05rem; font-weight: 700; color: #1d1d1f; letter-spacing: -.02em; margin: 0 0 .2rem; }
    .chapter-info p { font-size: .82rem; color: #86868b; margin: 0; }
    .chapter-arrow { font-size: 1rem; color: #86868b; transition: transform .3s; }
    .chapter-item.open .chapter-arrow { transform: rotate(180deg); }
    .chapter-body { display: none; padding: 0 2rem 2rem; }
    .chapter-item.open .chapter-body { display: block; }

    /* 이론 카드 */
    .theory-card { background: #f5f5f7; border-radius: 16px; padding: 1.5rem; margin-bottom: 1.5rem; }
    .theory-card h3 { font-size: .95rem; font-weight: 700; color: #1d1d1f; margin: 0 0 .75rem; }
    .theory-card p, .theory-card li { font-size: .9rem; color: #3a3a3c; line-height: 1.7; word-break: keep-all; }
    .theory-card ul { padding-left: 1.2rem; margin: .5rem 0; }

    /* 표 */
    table { width: 100%; border-collapse: collapse; font-size: .88rem; margin: .75rem 0; }
    th { background: #1d1d1f; color: #fff; padding: .6rem .9rem; text-align: left; font-weight: 600; }
    td { padding: .55rem .9rem; border-bottom: 1px solid #e5e5ea; color: #3a3a3c; line-height: 1.5; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr:nth-child(even) td { background: #fafafa; }
    .highlight { color: #0051c3; font-weight: 700; }
    .danger { color: #ff3b30; font-weight: 700; }

    /* 문제 */
    .quiz-section { margin-top: 1.5rem; }
    .quiz-section h3 { font-size: .9rem; font-weight: 700; color: #86868b; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 1rem; }
    .q-item { background: #fff; border: 2px solid #e5e5ea; border-radius: 16px; padding: 1.25rem 1.5rem; margin-bottom: 1rem; }
    .q-text { font-size: .95rem; color: #1d1d1f; line-height: 1.7; margin-bottom: .75rem; word-break: keep-all; }
    .q-text .blank { display: inline-block; background: #e8f1ff; color: #0051c3; padding: .1rem .6rem; border-radius: 6px; font-weight: 700; }
    .q-choices { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem; }
    .q-btn { background: #f5f5f7; border: 2px solid transparent; border-radius: 10px; padding: .6rem .9rem; font-size: .88rem; font-weight: 500; cursor: pointer; color: #1d1d1f; text-align: left; transition: all .15s; display: flex; align-items: center; gap: .5rem; }
    .q-btn:hover:not(:disabled) { border-color: #0051c3; background: #e8f1ff; color: #0051c3; }
    .q-btn.correct { background: #e8f9ee !important; border-color: #30d158 !important; color: #1a8a3c !important; }
    .q-btn.wrong { background: #fff0f0 !important; border-color: #ff3b30 !important; color: #cc0000 !important; }
    .q-btn:disabled { cursor: default; }
    .q-lbl { width: 1.4rem; height: 1.4rem; border-radius: 50%; background: #fff; font-size: .72rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .q-exp { display: none; margin-top: .75rem; padding: .75rem 1rem; background: #f5f5f7; border-radius: 10px; font-size: .85rem; color: #3a3a3c; line-height: 1.6; word-break: keep-all; }
    .q-exp.show { display: block; }
    .q-answer { color: #30d158; font-weight: 700; margin-top: .4rem; font-size: .82rem; }

    @media(max-width:600px){
      main { padding: 3rem 1rem; }
      .chapter-header { padding: 1.25rem 1.25rem; gap: .9rem; }
      .chapter-body { padding: 0 1.25rem 1.5rem; }
      .q-choices { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <Header />
  <main>
    <div class="page-header">
      <div class="badge">RC 문법 정리</div>
      <h1>토익 RC 문법 완전 정복</h1>
      <p>Part 5 / 6 필수 문법 기초부터 · 챕터별 실전 문제</p>
    </div>

    <div class="chapter-list" id="chapter-list">
      <!-- JS로 렌더링 -->
    </div>
  </main>
  <Footer />

<script>
const CHAPTERS = [
  {
    num: 1, title: "품사 (Parts of Speech)", sub: "명사·형용사·부사·동사 자리 구분 — 토익 Part 5 최빈출",
    color: "#0051c3",
    theory: `
      <div class="theory-card">
        <h3>📌 핵심 원칙: 빈칸의 '자리'를 먼저 봐라</h3>
        <p>토익 Part 5 품사 문제는 4개 보기가 같은 어근의 다른 품사입니다.<br>문장 구조에서 빈칸이 어떤 자리인지 파악하는 것이 핵심입니다.</p>
        <table>
          <tr><th>품사</th><th>자리</th><th>대표 예</th></tr>
          <tr><td><span class="highlight">명사</span></td><td>주어, 목적어, 보어, 전치사+___</td><td>decision, growth, employee</td></tr>
          <tr><td><span class="highlight">동사</span></td><td>주어 뒤, 조동사 뒤</td><td>provide, increase, submit</td></tr>
          <tr><td><span class="highlight">형용사</span></td><td>명사 앞, be동사 뒤(보어)</td><td>available, significant, recent</td></tr>
          <tr><td><span class="highlight">부사</span></td><td>동사·형용사·부사 앞뒤, 문장 앞뒤</td><td>significantly, recently, carefully</td></tr>
        </table>
      </div>
      <div class="theory-card">
        <h3>🔑 품사별 대표 어미 패턴</h3>
        <table>
          <tr><th>명사</th><td>-tion, -ness, -ment, -ity, -er/or, -ance/ence</td></tr>
          <tr><th>형용사</th><td>-ive, -ful, -ous, -al, -ble, -ent/ant</td></tr>
          <tr><th>부사</th><td>-ly (형용사+-ly)</td></tr>
          <tr><th>동사</th><td>-ize, -ify, -en, -ate</td></tr>
        </table>
        <p style="margin-top:.75rem;font-size:.82rem;color:#86868b;">⚠️ 주의: <span class="danger">costly, friendly, lovely, timely</span> 등은 -ly로 끝나지만 <strong>형용사</strong>입니다!</p>
      </div>`,
    quizzes: [
      { q: "The company's -------- to expand into new markets exceeded all expectations.", choices:["decide","decision","decisive","decisively"], ans:1, exp:"전치사 The company's 뒤, 주어 자리이므로 명사 <strong>decision</strong>이 정답. 동사 decide, 형용사 decisive, 부사 decisively는 주어 자리에 올 수 없습니다." },
      { q: "The new software update will -------- improve processing speed.", choices:["significant","significance","significantly","signify"], ans:2, exp:"조동사 will 뒤에는 동사원형이 오지만, 이미 improve가 있으므로 빈칸은 동사를 꾸미는 <strong>부사(significantly)</strong>가 정답입니다." },
      { q: "All -------- employees must complete the training program before starting work.", choices:["newly","new","newness","newer"], ans:1, exp:"명사 employees 앞에서 수식하는 역할은 <strong>형용사(new)</strong>가 합니다. newly hired employees라면 부사도 가능하지만 여기선 명사 바로 앞이므로 형용사입니다." },
      { q: "Ms. Park showed great -------- in handling the difficult client.", choices:["patient","patiently","patience","patientness"], ans:2, exp:"형용사 great의 수식을 받으면서 동사 showed의 목적어 역할을 하는 <strong>명사(patience)</strong>가 정답입니다." },
      { q: "The results of the survey were -------- encouraging.", choices:["extreme","extremity","extremely","extremeness"], ans:2, exp:"형용사 encouraging을 꾸미는 <strong>부사(extremely)</strong>가 정답입니다. 형용사를 강조하려면 부사가 필요합니다." }
    ]
  },
  {
    num: 2, title: "동사의 시제 (Tense)", sub: "현재·과거·미래·완료형 — 시간 표현 키워드로 판단",
    color: "#ff9f0a",
    theory: `
      <div class="theory-card">
        <h3>📌 토익 시제 판단 핵심 키워드</h3>
        <table>
          <tr><th>시제</th><th>단서 표현</th></tr>
          <tr><td><span class="highlight">현재</span></td><td>always, usually, often, every day/year, currently</td></tr>
          <tr><td><span class="highlight">과거</span></td><td>yesterday, last week/year, ago, in 2020, previously</td></tr>
          <tr><td><span class="highlight">미래</span></td><td>tomorrow, next week, soon, by + 미래날짜, will, be going to</td></tr>
          <tr><td><span class="highlight">현재완료</span></td><td>since, for + 기간, recently, already, yet, just, so far</td></tr>
          <tr><td><span class="highlight">과거완료</span></td><td>before/after + 과거, by the time + 과거절</td></tr>
        </table>
      </div>
      <div class="theory-card">
        <h3>🔑 미래 표현 완벽 정리</h3>
        <table>
          <tr><th>표현</th><th>뉘앙스</th><th>예</th></tr>
          <tr><td>will</td><td>단순 미래/의지</td><td>The meeting will start at 9.</td></tr>
          <tr><td>be going to</td><td>계획된 미래</td><td>We are going to launch next month.</td></tr>
          <tr><td>be + -ing</td><td>확정된 미래 일정</td><td>She is leaving tomorrow.</td></tr>
          <tr><td>be about to</td><td>막 ~하려는 참</td><td>The train is about to depart.</td></tr>
        </table>
        <p style="margin-top:.75rem;font-size:.82rem;color:#86868b;">⚠️ <span class="danger">시간/조건 부사절</span>에서는 미래 내용이라도 현재시제 사용! (when, if, after, before, until, as soon as + 현재시제)</p>
      </div>`,
    quizzes: [
      { q: "The annual conference -------- in Chicago since it was first held in 2010.", choices:["has been held","held","will hold","is holding"], ans:0, exp:"since 2010이라는 시작점이 있고 현재까지 계속되므로 <strong>현재완료(has been held)</strong>가 정답입니다." },
      { q: "The manager -------- to Tokyo last week to attend a trade fair.", choices:["travels","will travel","traveled","has traveled"], ans:2, exp:"last week이라는 명확한 과거 시점 표시어가 있으므로 <strong>단순 과거(traveled)</strong>가 정답입니다. 현재완료는 last week과 함께 쓸 수 없습니다." },
      { q: "Please submit your report before the deadline --------.", choices:["arrive","arrives","will arrive","arrived"], ans:1, exp:"before는 시간 부사절 접속사이므로 미래 내용이어도 <strong>현재시제(arrives)</strong>를 씁니다. 'before the deadline arrives' = '마감일이 되기 전에'" },
      { q: "The construction of the new bridge -------- by the end of next year.", choices:["will complete","will have been completed","has completed","completed"], ans:1, exp:"by the end of next year(미래 완료 시점)이므로 <strong>미래완료 수동태(will have been completed)</strong>가 정답입니다." }
    ]
  },
  {
    num: 3, title: "수일치 (Subject-Verb Agreement)", sub: "단수/복수 구분 — 수식어에 속지 마라",
    color: "#ff3b30",
    theory: `
      <div class="theory-card">
        <h3>📌 핵심 원칙: 진짜 주어를 찾아라</h3>
        <p>전치사구·관계절 등 수식어가 주어와 동사 사이에 끼어들어도 <strong>핵심 주어</strong>만 보고 수일치를 결정합니다.</p>
        <table>
          <tr><th>주어 유형</th><th>동사</th><th>예</th></tr>
          <tr><td>단수명사 / 불가산명사</td><td>단수동사 (-s)</td><td>The information <span class="highlight">is</span> accurate.</td></tr>
          <tr><td>복수명사</td><td>복수동사</td><td>The employees <span class="highlight">are</span> trained.</td></tr>
          <tr><td>each/every + 단수명사</td><td>단수동사</td><td>Each employee <span class="highlight">has</span> a badge.</td></tr>
          <tr><td>A and B</td><td>복수동사</td><td>Tom and Jane <span class="highlight">are</span> here.</td></tr>
          <tr><td>either A or B / neither A nor B</td><td>B에 일치</td><td>Neither the CEO nor the managers <span class="highlight">were</span> present.</td></tr>
          <tr><td>A as well as B / A along with B</td><td>A에 일치</td><td>The director, along with his team, <span class="highlight">is</span> attending.</td></tr>
        </table>
      </div>
      <div class="theory-card">
        <h3>🔑 헷갈리는 단수 취급 명사</h3>
        <table>
          <tr><th>표현</th><th>기억법</th></tr>
          <tr><td>the number of + 복수명사</td><td>"수(number) 자체" → 단수 / a number of = 많은 → 복수</td></tr>
          <tr><td>every, each, either, neither + 단수명사</td><td>항상 단수동사</td></tr>
          <tr><td>불가산명사 (information, advice, equipment, furniture, luggage)</td><td>s 없음, 단수동사</td></tr>
          <tr><td>동명사/to부정사 주어</td><td>단수동사</td></tr>
        </table>
      </div>`,
    quizzes: [
      { q: "The number of participants in the training session -------- increased significantly.", choices:["have","has","are","were"], ans:1, exp:"'the number of'는 '수'를 나타내는 단수 주어이므로 <strong>has</strong>가 정답. 반면 'a number of participants = 많은 참가자들'이면 복수동사를 씁니다." },
      { q: "Neither the president nor the board members -------- willing to accept the proposal.", choices:["was","is","were","has been"], ans:2, exp:"'neither A nor B' 구조에서 동사는 B(board members = 복수)에 일치시키므로 <strong>were</strong>가 정답입니다." },
      { q: "Each of the new products -------- been thoroughly tested before release.", choices:["have","has","were","are"], ans:1, exp:"'each of + 복수명사'는 단수 취급이므로 <strong>has</strong>가 정답입니다." }
    ]
  },
  {
    num: 4, title: "대명사 (Pronouns)", sub: "인칭/재귀/소유격 — 격(Case)을 맞춰라",
    color: "#5e5ce6",
    theory: `
      <div class="theory-card">
        <h3>📌 대명사 격 정리표</h3>
        <table>
          <tr><th>인칭</th><th>주격</th><th>목적격</th><th>소유격</th><th>소유대명사</th><th>재귀대명사</th></tr>
          <tr><td>1인칭 단수</td><td>I</td><td>me</td><td>my</td><td>mine</td><td>myself</td></tr>
          <tr><td>2인칭</td><td>you</td><td>you</td><td>your</td><td>yours</td><td>yourself</td></tr>
          <tr><td>3인칭 남</td><td>he</td><td>him</td><td>his</td><td>his</td><td>himself</td></tr>
          <tr><td>3인칭 여</td><td>she</td><td>her</td><td>her</td><td>hers</td><td>herself</td></tr>
          <tr><td>3인칭 복수</td><td>they</td><td>them</td><td>their</td><td>theirs</td><td>themselves</td></tr>
        </table>
      </div>
      <div class="theory-card">
        <h3>🔑 재귀대명사 용법</h3>
        <ul>
          <li><strong>재귀 용법</strong>: 주어 = 목적어일 때 → She injured <span class="highlight">herself</span>.</li>
          <li><strong>강조 용법</strong>: 주어/목적어 바로 뒤 → The CEO <span class="highlight">himself</span> attended.</li>
          <li>⚠️ 재귀대명사는 주어 자리에 올 수 없음!</li>
        </ul>
      </div>`,
    quizzes: [
      { q: "The marketing team submitted -------- report ahead of the deadline.", choices:["they","them","their","theirs"], ans:2, exp:"명사 report 앞에서 수식하는 자리이므로 소유격 <strong>their</strong>가 정답입니다." },
      { q: "The director prepared the presentation -------- without any assistance.", choices:["her","hers","she","herself"], ans:3, exp:"주어(The director)와 동일 대상이 직접 했음을 강조하는 강조 용법의 <strong>재귀대명사(herself)</strong>가 정답입니다." },
      { q: "The new policy will benefit all employees, including --------.", choices:["we","our","us","ours"], ans:2, exp:"전치사 including 뒤에는 목적격이 와야 하므로 <strong>us</strong>가 정답입니다." }
    ]
  },
  {
    num: 5, title: "관계사 (Relative Clauses)", sub: "who/which/that/where/when/whose — 선행사로 판단",
    color: "#34aadc",
    theory: `
      <div class="theory-card">
        <h3>📌 관계대명사 선택 기준</h3>
        <table>
          <tr><th>선행사</th><th>주격</th><th>목적격</th><th>소유격</th></tr>
          <tr><td>사람</td><td>who</td><td>whom</td><td>whose</td></tr>
          <tr><td>사물/동물</td><td>which</td><td>which</td><td>whose/of which</td></tr>
          <tr><td>사람+사물</td><td>that</td><td>that</td><td>—</td></tr>
        </table>
      </div>
      <div class="theory-card">
        <h3>🔑 관계부사 (선행사 + 전치사 대체)</h3>
        <table>
          <tr><th>관계부사</th><th>선행사</th><th>예문</th></tr>
          <tr><td>where</td><td>장소</td><td>the city <span class="highlight">where</span> she was born</td></tr>
          <tr><td>when</td><td>시간</td><td>the day <span class="highlight">when</span> we met</td></tr>
          <tr><td>why</td><td>reason</td><td>the reason <span class="highlight">why</span> he left</td></tr>
          <tr><td>how</td><td>the way (함께 못 씀)</td><td>the way <span class="highlight">he solved</span> it</td></tr>
        </table>
