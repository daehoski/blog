function renderChapters() {
  const list = document.getElementById('chapter-list');
  list.innerHTML = CHAPTERS.map((ch, ci) => `
    <div class="chapter-item" id="ch-${ci}">
      <div class="chapter-header" onclick="toggleChapter(${ci})">
        <div class="chapter-num" style="background:${ch.color}">${ch.num}</div>
        <div class="chapter-info">
          <h2>${ch.title}</h2>
          <p>${ch.sub}</p>
        </div>
        <span class="chapter-arrow">▼</span>
      </div>
      <div class="chapter-body">
        ${ch.theory}
        <div class="quiz-section">
          <h3>✏️ 실전 문제 (${ch.quizzes.length}문제)</h3>
          ${ch.quizzes.map((q, qi) => renderQuiz(q, ci, qi)).join('')}
        </div>
      </div>
    </div>
  `).join('');
}

function renderQuiz(q, ci, qi) {
  const labels = ['A','B','C','D'];
  const choices = q.choices.map((c, i) => `
    <button class="q-btn" id="qbtn-${ci}-${qi}-${i}" onclick="answerQ(${ci},${qi},${i},${q.ans})">
      <span class="q-lbl">${labels[i]}</span>${c}
    </button>`).join('');
  return `
    <div class="q-item" id="qitem-${ci}-${qi}">
      <div class="q-text">Q${qi+1}. ${q.q.replace(/--------/g, '<span class="blank">___</span>')}</div>
      <div class="q-choices">${choices}</div>
      <div class="q-exp" id="qexp-${ci}-${qi}">
        ${q.exp}
        <div class="q-answer">✅ 정답: (${labels[q.ans]}) ${q.choices[q.ans]}</div>
      </div>
    </div>`;
}

function toggleChapter(ci) {
  const item = document.getElementById('ch-' + ci);
  item.classList.toggle('open');
}

function answerQ(ci, qi, chosen, correct) {
  const btns = document.querySelectorAll(`[id^="qbtn-${ci}-${qi}-"]`);
  btns.forEach((btn, i) => {
    btn.disabled = true;
    if (i === correct) btn.classList.add('correct');
    else if (i === chosen && chosen !== correct) btn.classList.add('wrong');
  });
  document.getElementById(`qexp-${ci}-${qi}`).classList.add('show');
}

window.toggleChapter = toggleChapter;
window.answerQ = answerQ;

renderChapters();
</script>
