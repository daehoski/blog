---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { allQuizData } from '../../data/all-quiz-data.js';
import { quizSlugMap } from '../../lib/utils.js';

// 전체 퀴즈 목록 (네비게이션용) - 숫자 순서로 정렬
const allRanges = Object.keys(allQuizData).sort((a, b) => {
  const getStart = (s) => parseInt(s.replace('q', '').split('-')[0]);
  return getStart(a) - getStart(b);
});

const getDisplayRange = (r) => {
  const parts = r.replace('q', '').split('-');
  if (parts.length === 2) {
    return `${parseInt(parts[0])}~${parseInt(parts[1])}번`;
  }
  return r;
};
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`AWS SAA C03 연습 문제 전체 목록 | ${SITE_TITLE}`} description="AWS SAA-C03 실전 대비 연습 문제 전체 목록입니다. 원하는 회차를 선택해 학습을 시작하세요." />
		<style>
			main {
				width: 100%;
				max-width: 1100px;
				margin: 0 auto;
				padding: 4rem 1.5rem;
				overflow-x: hidden;
			}
			.quiz-list-container {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 2rem;
				margin-top: 2rem;
				max-width: 100%;
			}
			.quiz-card {
				background: white;
				padding: 3rem 2rem;
				border-radius: 24px;
				box-shadow: var(--box-shadow);
				text-decoration: none;
				color: inherit;
				transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
				border: none;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
			}
			.quiz-card:hover {
				transform: translateY(-8px);
				box-shadow: var(--box-shadow-hover);
			}
			.quiz-card h3 {
				margin: 0 0 0.75rem 0;
				font-size: 1.35rem;
				color: #1d1d1f;
				font-weight: 700;
				letter-spacing: -0.03em;
				word-break: keep-all;
			}
			.quiz-card p {
				margin: 0;
				font-size: 0.95rem;
				color: #86868b;
				line-height: 1.5;
				font-weight: 400;
				word-break: keep-all;
			}
			.quiz-badge {
				display: inline-block;
				padding: 0.35rem 0.9rem;
				background: #f5f5f7;
				color: #1d1d1f;
				border-radius: 9999px;
				font-size: 0.75rem;
				font-weight: 600;
				margin-bottom: 1.25rem;
				align-self: flex-start;
				letter-spacing: 0.02em;
			}
			.quiz-link-text {
				margin-top: 2rem;
				font-weight: 600;
				color: #1d1d1f;
				font-size: 0.9rem;
				display: flex;
				align-items: center;
				gap: 0.4rem;
				transition: gap 0.2s;
			}
			.quiz-card:hover .quiz-link-text {
				gap: 0.6rem;
			}
			@media (max-width: 768px) {
				main {
					padding: 3rem 1.25rem;
				}
				.quiz-list-container {
					grid-template-columns: 1fr;
					gap: 1.25rem;
				}
				.quiz-card {
					padding: 2rem 1.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section style="text-align: center; margin-bottom: 5rem;">
				<h1 style="font-size: 3.5rem; margin-bottom: 1.5rem; color: #1d1d1f; font-weight: 800; letter-spacing: -0.04em;">AWS SAA-C03 실전 연습 문제</h1>
				<p style="color: #86868b; font-size: 1.2rem; line-height: 1.6; font-weight: 500; max-width: 600px; margin: 0 auto;">
					총 723개 문항을 25문제씩 관리하기 쉽게 구성했습니다. 가장 직관적인 환경에서 학습을 시작하세요.
				</p>
			</section>

			<div class="quiz-list-container">
				{allRanges.map((range) => (
					<a href={`/quiz/${quizSlugMap[range] || range}/`} class="quiz-card">
                        <div>
                            <span class="quiz-badge">SAA-C03</span>
						    <h3>{getDisplayRange(range)}</h3>
						    <p>{allQuizData[range].length}개의 문제가 포함되어 있습니다.</p>
                        </div>
                        <div class="quiz-link-text">
                            실전 퀴즈 풀기 →
                        </div>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
