---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { allQuizData } from '../../data/all-quiz-data.js';
import { supabase } from '../../lib/supabase.js';
import '../../styles/quiz.css';

export function getStaticPaths() {
  return Object.keys(allQuizData).map(range => ({
    params: { range }
  }));
}

const { range } = Astro.params;
const quizData = allQuizData[range] || [];

// 퀴즈 범위 정보를 기반으로 타이틀 동적 생성
const getDisplayRange = (r) => {
  const parts = r.replace('q', '').split('-');
  if (parts.length === 2) {
    return `${parseInt(parts[0])}~${parseInt(parts[1])}번`;
  }
  return r;
};

const title = `AWS SAA C03 연습 문제 (${getDisplayRange(range)})`;
const description = `AWS SAA-C03 실전 대비 연습 문제 ${getDisplayRange(range)}를 풀어보고 오답 노트를 확인하세요.`;

// 전체 퀴즈 목록 (네비게이션용) - 숫자 순서로 정렬
const allRanges = Object.keys(allQuizData).sort((a, b) => {
  const getStart = (s) => parseInt(s.replace('q', '').split('-')[0]);
  return getStart(a) - getStart(b);
});
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<div class="quiz-container">
				<nav class="quiz-top-nav">
					<a href="/quiz" id="back-to-list" class="back-link">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="15 18 9 12 15 6"></polyline>
						</svg>
						목록으로
					</a>
				</nav>

				<header id="main-quiz-header" class="mobile-hidden" style="text-align: center; margin-bottom: 2rem;">
					<h1 style="font-size: 1.7rem; margin-bottom: 0.5rem; font-weight: 800; letter-spacing: -0.04em;">{title}</h1>
					<p style="color: #86868b; font-size: 0.95rem; font-weight: 500;">실제 기출문제를 풀고 실력을 점검해 보세요.</p>
				</header>

				{quizData.length > 0 ? (
                    <div id="quiz-wrapper">
                        <form id="quiz-form">
                            {quizData.map((quiz, index) => (
                                <article 
                                    class="quiz-card" 
                                    id={`quiz-${quiz.id}`} 
                                    data-quiz-id={quiz.id}
                                    data-answer={JSON.stringify(quiz.answer)} 
                                    data-explanations={JSON.stringify(quiz.explanations || {})}
                                    data-category={quiz.domain || "기본"}
                                    data-legacy-explanation={quiz.explanation}
                                >
                                    <div class="quiz-question-header">
                                        <span class="quiz-badge">Q{quiz.id}</span>
                                        <h2 class="quiz-question-text">{quiz.question}</h2>
                                    </div>

                                    <div class="quiz-options">
                                        {quiz.options.map((option, optIndex) => (
                                            <label class="quiz-option" for={`q${quiz.id}-opt${optIndex}`}>
                                                <input 
                                                    type={Array.isArray(quiz.answer) ? "checkbox" : "radio"} 
                                                    name={`q${quiz.id}`} 
                                                    id={`q${quiz.id}-opt${optIndex}`} 
                                                    value={optIndex}
                                                />
                                                <span class="quiz-option-text">{option}</span>
                                            </label>
                                        ))}
                                    </div>

                                    <button type="button" class="quiz-btn grade-btn" data-quiz-id={quiz.id}>
                                        정답 확인 및 해설
                                    </button>

                                    <div class="quiz-result-area hidden" id={`result-${quiz.id}`}>
                                        <div class="quiz-explanation">
                                            <div class="quiz-explanation-title">
                                                <span>📖 맞춤 해설</span>
                                            </div>
                                            <div id={`explanation-content-${quiz.id}`} class="explanation-text">
                                                {/* 선택지에 따른 해설이 동적으로 삽입될 위치 */}
                                                {!quiz.explanations && <p>{quiz.explanation}</p>}
                                            </div>
                                        </div>

                                        {quiz.glossary && Object.keys(quiz.glossary).length > 0 && (
                                            <div class="quiz-glossary">
                                                <div class="quiz-glossary-title">
                                                    <span>💡 이 문제의 핵심 용어</span>
                                                </div>
                                                <ul class="quiz-glossary-list">
                                                    {Object.entries(quiz.glossary).map(([term, desc]) => (
                                                        <li class="quiz-glossary-item">
                                                            <span class="quiz-glossary-term">{term}</span>: {desc}
                                                        </li>
                                                    ))}
                                                </ul>
                                            </div>
                                        )}
                                    </div>
                                </article>
                            ))}
                        </form>
                    </div>
                ) : (
                    <div style="text-align: center; padding: 4rem; background: white; border-radius: 12px; box-shadow: var(--box-shadow);">
                        <p style="font-size: 1.25rem; color: #666;">데이터를 준비 중입니다. 잠시만 기다려 주세요! 🚧</p>
                    </div>
                )}

				<div class="quiz-summary-card">
					<button id="show-summary-btn" class="quiz-btn summary-card-btn">
						최종 결과 및 오답 노트 보기
					</button>

					<div id="summary-result" class="hidden">
						<div class="quiz-score-circle">
							<span id="final-score">0</span>
							<span class="quiz-score-text">/ {quizData.length}</span>
						</div>
						<p id="score-message" style="font-weight: 700; font-size: 1.1rem; margin-bottom: 2rem;"></p>
						
						<div class="quiz-wrong-review" id="wrong-answer-note">
							<h3 style="border-bottom: 2px solid #e5e7eb; padding-bottom: 0.5rem; margin-bottom: 1rem;">📝 오답 노트</h3>
							<div id="wrong-list-container"></div>
						</div>
					</div>
				</div>

				<!-- 하단 퀴즈 네비게이션 -->
				<div class="quiz-nav-section" style="margin-top: 3rem; padding-top: 1.5rem; border-top: 2px solid #e5e7eb;">
					<h3 style="margin-bottom: 1rem; text-align: center; font-size: 1rem; color: #374151;">🎯 다른 회차 풀어보기</h3>
					<div class="quiz-nav-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 0.75rem;">
						{allRanges.filter(r => r.startsWith('q')).map((r) => (
							<a 
								href={`/quiz/${r}`} 
								class={`quiz-nav-item ${r === range ? 'active' : ''}`}
								style={`
									display: block;
									padding: 0.6rem;
									text-align: center;
									background: ${r === range ? '#2563eb' : 'white'};
									color: ${r === range ? 'white' : '#4b5563'};
									border: 1px solid ${r === range ? '#2563eb' : '#e5e7eb'};
									border-radius: 6px;
									text-decoration: none;
									font-size: 0.85rem;
									font-weight: 500;
									transition: all 0.2s;
								`}
							>
								{getDisplayRange(r)}
							</a>
						))}
					</div>
				</div>
			</div>

            <!-- Exit Confirmation Modal (Glassmorphism) -->
            <div id="exit-modal" class="modal-overlay hidden">
                <div class="modal-content glass">
                    <h3>퀴즈를 중단하시겠습니까?</h3>
                    <p>지금까지의 진행 상황이 저장되지 않을 수 있습니다.</p>
                    <div class="modal-buttons">
                        <button id="modal-continue" class="modal-btn secondary">계속 풀기</button>
                        <button id="modal-exit" class="modal-btn primary">나가기</button>
                    </div>
                </div>
            </div>
		</main>
		<Footer />

		<script>
            import { supabase } from '../../lib/supabase.js';

			document.addEventListener('DOMContentLoaded', async () => {
				const gradeButtons = document.querySelectorAll('.grade-btn');
				const showSummaryBtn = document.getElementById('show-summary-btn');
				const userSelections = {};

                // Get User Session
                const { data: { session } } = await supabase.auth.getSession();
                const userId = session?.user?.id;

                // Exit Modal Logic
                const backBtn = document.getElementById('back-to-list');
                const exitModal = document.getElementById('exit-modal');
                const modalContinue = document.getElementById('modal-continue');
                const modalExit = document.getElementById('modal-exit');
                let pendingExitUrl = '';

                const showExitModal = (e, url) => {
                    const hasStarted = Object.keys(userSelections).length > 0;
                    if (hasStarted) {
                        e.preventDefault();
                        pendingExitUrl = url;
                        exitModal?.classList.remove('hidden');
                    }
                };

                backBtn?.addEventListener('click', (e) => showExitModal(e, '/quiz'));
                
                document.querySelectorAll('.logo a, .internal-links a').forEach(link => {
                    link.addEventListener('click', (e) => {
                        const href = (link as HTMLAnchorElement).getAttribute('href');
                        if (href) showExitModal(e, href);
                    });
                });

                modalContinue?.addEventListener('click', () => {
                    exitModal?.classList.add('hidden');
                });

                modalExit?.addEventListener('click', () => {
                    window.location.href = pendingExitUrl;
                });

				// 개별 문제 채점
				gradeButtons.forEach(btn => {
					btn.addEventListener('click', async () => {
						const quizId = parseInt(btn.dataset.quizId || "0");
						const quizCard = document.getElementById(`quiz-${quizId}`);
                        if (!quizCard) return;

                        let correctAnswerList = [];
                        let selectedOptions = [];
                        let explanations = {};

                        try {
						    const isMultiple = Array.isArray(JSON.parse(quizCard.dataset.answer || "[]"));
                            
                            if (isMultiple) {
                                selectedOptions = Array.from(quizCard.querySelectorAll(`input[name="q${quizId}"]:checked`)).map(el => parseInt((el as HTMLInputElement).value));
                            } else {
                                const selected = quizCard.querySelector(`input[name="q${quizId}"]:checked`) as HTMLInputElement;
                                selectedOptions = selected ? [parseInt(selected.value)] : [];
                            }

						    if (selectedOptions.length === 0) {
							    alert("답을 선택해 주세요!");
							    return;
						    }

						    userSelections[quizId] = selectedOptions;
                            const correctAnswers = JSON.parse(quizCard.dataset.answer || "[]");
                            correctAnswerList = Array.isArray(correctAnswers) ? correctAnswers : [correctAnswers];
                            explanations = JSON.parse(quizCard.dataset.explanations || '{}');
                        } catch (e) {
                            console.error('Data parsing error:', e);
                        }

						// UI 업데이트 (항상 실행되어야 함)
						const options = quizCard.querySelectorAll('.quiz-option');
						options.forEach((opt) => {
							const input = opt.querySelector('input') as HTMLInputElement;
							input.disabled = true;
							opt.classList.add('disabled');

							if (correctAnswerList.includes(parseInt(input.value))) {
								opt.classList.add('correct');
							} else if (selectedOptions.includes(parseInt(input.value))) {
								opt.classList.add('wrong');
							}
						});

                        // Explanations Display
                        const expContainer = document.getElementById(`explanation-content-${quizId}`);
                        if (expContainer) {
                            expContainer.innerHTML = '';
                            
                            // User's wrong choices explanations
                            selectedOptions.forEach(idx => {
                                if (!correctAnswerList.includes(idx) && explanations[idx]) {
                                    const p = document.createElement('p');
                                    p.className = 'exp-wrong';
                                    p.style.color = '#ef4444';
                                    p.style.fontSize = '0.9rem';
                                    p.style.marginBottom = '0.5rem';
                                    p.innerHTML = `<strong>❌ 선택 오답 (${String.fromCharCode(65 + idx)}):</strong> ${explanations[idx]}`;
                                    expContainer.appendChild(p);
                                }
                            });

                            // Correct answers explanations
                            correctAnswerList.forEach(idx => {
                                if (explanations[idx]) {
                                    const p = document.createElement('p');
                                    p.className = 'exp-correct';
                                    p.style.color = '#10b981';
                                    p.style.fontSize = '0.9rem';
                                    p.style.marginBottom = '0.5rem';
                                    p.innerHTML = `<strong>✅ 정답 (${String.fromCharCode(65 + idx)}):</strong> ${explanations[idx]}`;
                                    expContainer.appendChild(p);
                                }
                            });

                            // Fallback to legacy explanation if empty
                            if (expContainer.innerHTML === '' && quizCard.dataset.legacyExplanation) {
                                expContainer.innerHTML = `<p>${quizCard.dataset.legacyExplanation}</p>`;
                            }
                        }

						btn.classList.add('hidden');
						const resultArea = document.getElementById(`result-${quizId}`);
                        if (resultArea) resultArea.classList.remove('hidden');

                        // --- Supabase Interaction (Isolated in try-catch) ---
                        const { data: { session: freshSession } } = await supabase.auth.getSession();
                        if (freshSession && freshSession.user) {
                            const currentUserId = freshSession.user.id;
                            
                            // 1. Progress Upsert
                            try {
                                const progressPayload = {
                                    user_id: currentUserId,
                                    last_quiz_id: quizId,
                                    updated_at: new Date().toISOString()
                                };
                                await supabase.from('user_progress').upsert(progressPayload);
                            } catch (e) {
                                console.error('User progress save error:', e);
                            }

                            // 2. Wrong Answer Tracking
                            try {
                                const wrongAnswerPayload = {
                                    user_id: currentUserId,
                                    question_id: String(quizId)
                                };
                                console.log("Attempting Insert - Payload:", wrongAnswerPayload);
                                
                                const { data, error } = await supabase.from('wrong_answers').insert(wrongAnswerPayload);
                                
                                if (error) {
                                    console.error('Supabase 403/Forbidden Diagnostic:', {
                                        message: error.message,
                                        details: error.details,
                                        hint: error.hint,
                                        code: error.code,
                                        status: error.status
                                    });
                                } else {
                                    console.log('Wrong answer saved successfully.');
                                }
                            } catch (e) {
                                console.error('Unexpected JS error during insert:', e);
                            }
                        }
					});
				});

				// 최종 결과 보기
				showSummaryBtn?.addEventListener('click', () => {
					let correctCount = 0;
                    const domainStats = {};
					const wrongListContainer = document.getElementById('wrong-list-container');
					if (!wrongListContainer) return;
                    wrongListContainer.innerHTML = '';

                    const quizCards = document.querySelectorAll('.quiz-card');
                    
					quizCards.forEach((quizCard : any) => {
                        const quizId = parseInt(quizCard.dataset.quizId);
                        const domain = quizCard.dataset.category || "기본";
                        
                        if (!domainStats[domain]) domainStats[domain] = { total: 0, wrong: 0 };
                        domainStats[domain].total++;

						const userChoices = userSelections[quizId] || [];
						const correctAnswers = JSON.parse(quizCard.dataset.answer);
						const correctAnswerList = Array.isArray(correctAnswers) ? correctAnswers : [correctAnswers];
						
                        const isCorrect = userChoices.length === correctAnswerList.length && 
                                          userChoices.every((val : any) => correctAnswerList.includes(val));

						if (isCorrect) {
							correctCount++;
						} else {
                            domainStats[domain].wrong++;
							const wrongItem = document.createElement('div');
							wrongItem.className = 'quiz-wrong-item';
							
                            const questionText = quizCard.querySelector('.quiz-question-text')?.textContent;
                            const optionsList = Array.from(quizCard.querySelectorAll('.quiz-option-text')).map((el : any) => el.textContent);

							const userChoiceTexts = userChoices.length > 0 
                                ? userChoices.map((idx : any) => optionsList[idx]).join(', ') 
                                : "미선택";
							const correctChoiceTexts = correctAnswerList.map((idx : any) => optionsList[idx]).join(', ');

							wrongItem.innerHTML = `
								<div style="margin-bottom: 0.5rem;">
									<span class="quiz-badge" style="background:#ef4444;">Q${quizId}</span>
                                    <span class="quiz-badge" style="background:#6b7280; margin-left: 0.5rem;">${domain}</span>
									<strong style="margin-left:0.5rem;">${questionText}</strong>
								</div>
								<div style="font-size: 0.9rem; margin-bottom: 0.5rem; padding: 0.5rem; background: #fff1f2; border-radius: 4px;">
									❌ 내 답변: ${userChoiceTexts}
								</div>
								<div style="font-size: 0.9rem; margin-bottom: 0.5rem; padding: 0.5rem; background: #f0fdf4; border-radius: 4px;">
									✅ 정답: ${correctChoiceTexts}
								</div>
							`;
							wrongListContainer.appendChild(wrongItem);
						}
					});

                    // Render Domain Stats
                    const statsHeader = document.createElement('div');
                    statsHeader.className = 'domain-stats-container';
                    statsHeader.innerHTML = '<h3 style="margin-top: 2rem; margin-bottom: 1rem;">📊 도메인별 취약점 분석</h3>';
                    
                    Object.entries(domainStats).forEach(([domain, stats] : [string, any]) => {
                        const correct = stats.total - stats.wrong;
                        const percent = Math.round((correct / stats.total) * 100);
                        const statItem = document.createElement('div');
                        statItem.className = 'domain-stat-item';
                        statItem.style.marginBottom = '1rem';
                        statItem.innerHTML = `
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.25rem; font-size: 0.9rem;">
                                <span>${domain}</span>
                                <span>${percent}% (${correct}/${stats.total})</span>
                            </div>
                            <div style="width: 100%; height: 8px; background: #e5e7eb; border-radius: 4px; overflow: hidden;">
                                <div style="width: ${percent}%; height: 100%; background: ${percent < 50 ? '#ef4444' : percent < 80 ? '#f59e0b' : '#10b981'};"></div>
                            </div>
                        `;
                        statsHeader.appendChild(statItem);
                    });
                    
                    wrongListContainer.prepend(statsHeader);

					const finalScoreEl = document.getElementById('final-score');
                    if (finalScoreEl) finalScoreEl.textContent = correctCount.toString();
					
                    const summaryResult = document.getElementById('summary-result');
                    if (summaryResult) summaryResult.classList.remove('hidden');
					
					const totalQuestions = quizCards.length;
					const message = correctCount === totalQuestions 
						? "🎉 만점입니다! 완벽해요!" 
						: correctCount >= totalQuestions * 0.8 
							? "👍 아주 훌륭한 성적입니다!" 
							: `📖 ${totalQuestions}문제 중 ${correctCount}문제를 맞혔습니다. 오답 노트를 확인해 보세요.`;
					
                    const scoreMsgEl = document.getElementById('score-message');
                    if (scoreMsgEl) scoreMsgEl.textContent = message;

					showSummaryBtn?.classList.add('hidden');
					
					setTimeout(() => {
						document.getElementById('summary-result')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
					}, 100);
				});
			});
		</script>
	</body>
</html>
