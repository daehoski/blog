---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { allQuizData } from '../../data/all-quiz-data.js';
import '../../styles/quiz.css';

export function getStaticPaths() {
  return Object.keys(allQuizData).map(range => ({
    params: { range }
  }));
}

const { range } = Astro.params;
const quizData = allQuizData[range] || [];

// 퀴즈 범위 정보를 기반으로 타이틀 동적 생성
const getDisplayRange = (r) => {
  const parts = r.replace('q', '').split('-');
  if (parts.length === 2) {
    return `${parseInt(parts[0])}~${parseInt(parts[1])}번`;
  }
  return r;
};

const title = `AWS SAA C03 덤프 (${getDisplayRange(range)})`;
const description = `AWS SAA-C03 덤프 문제 ${getDisplayRange(range)}를 인터랙티브하게 풀어보고 오답 노트를 확인하세요.`;

// 전체 퀴즈 목록 (네비게이션용) - 숫자 순서로 정렬
const allRanges = Object.keys(allQuizData).sort((a, b) => {
  const getStart = (s) => parseInt(s.replace('q', '').split('-')[0]);
  return getStart(a) - getStart(b);
});
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<div class="quiz-container">
				<nav class="quiz-top-nav">
					<a href="/quiz" id="back-to-list" class="back-link">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="15 18 9 12 15 6"></polyline>
						</svg>
						목록으로
					</a>
				</nav>

				<header id="main-quiz-header" class="mobile-hidden" style="text-align: center; margin-bottom: 2rem;">
					<h1 style="font-size: 1.7rem; margin-bottom: 0.5rem; font-weight: 800; letter-spacing: -0.04em;">{title}</h1>
					<p style="color: #86868b; font-size: 0.95rem; font-weight: 500;">실제 기출문제를 풀고 실력을 점검해 보세요.</p>
				</header>

				{quizData.length > 0 ? (
                    <div id="quiz-wrapper">
                        <form id="quiz-form">
                            {quizData.map((quiz, index) => (
                                <article class="quiz-card" id={`quiz-${quiz.id}`} data-answer={JSON.stringify(quiz.answer)}>
                                    <div class="quiz-question-header">
                                        <span class="quiz-badge">Q{quiz.id}</span>
                                        <h2 class="quiz-question-text">{quiz.question}</h2>
                                    </div>

                                    <div class="quiz-options">
                                        {quiz.options.map((option, optIndex) => (
                                            <label class="quiz-option" for={`q${quiz.id}-opt${optIndex}`}>
                                                <input 
                                                    type={Array.isArray(quiz.answer) ? "checkbox" : "radio"} 
                                                    name={`q${quiz.id}`} 
                                                    id={`q${quiz.id}-opt${optIndex}`} 
                                                    value={optIndex}
                                                />
                                                <span class="quiz-option-text">{option}</span>
                                            </label>
                                        ))}
                                    </div>

                                    <button type="button" class="quiz-btn grade-btn" data-quiz-id={quiz.id}>
                                        정답 확인 및 해설
                                    </button>

                                    <div class="quiz-result-area hidden" id={`result-${quiz.id}`}>
                                        <div class="quiz-explanation">
                                            <div class="quiz-explanation-title">
                                                <span>📖 해설</span>
                                            </div>
                                            <p class="explanation-text">{quiz.explanation}</p>
                                        </div>

                                        {quiz.glossary && Object.keys(quiz.glossary).length > 0 && (
                                            <div class="quiz-glossary">
                                                <div class="quiz-glossary-title">
                                                    <span>💡 이 문제의 핵심 용어</span>
                                                </div>
                                                <ul class="quiz-glossary-list">
                                                    {Object.entries(quiz.glossary).map(([term, desc]) => (
                                                        <li class="quiz-glossary-item">
                                                            <span class="quiz-glossary-term">{term}</span>: {desc}
                                                        </li>
                                                    ))}
                                                </ul>
                                            </div>
                                        )}
                                    </div>
                                </article>
                            ))}
                        </form>
                    </div>
                ) : (
                    <div style="text-align: center; padding: 4rem; background: white; border-radius: 12px; box-shadow: var(--box-shadow);">
                        <p style="font-size: 1.25rem; color: #666;">데이터를 준비 중입니다. 잠시만 기다려 주세요! 🚧</p>
                    </div>
                )}

				<div class="quiz-summary-card">
					<button id="show-summary-btn" class="quiz-btn summary-card-btn">
						최종 결과 및 오답 노트 보기
					</button>

					<div id="summary-result" class="hidden">
						<div class="quiz-score-circle">
							<span id="final-score">0</span>
							<span class="quiz-score-text">/ {quizData.length}</span>
						</div>
						<p id="score-message" style="font-weight: 700; font-size: 1.1rem; margin-bottom: 2rem;"></p>
						
						<div class="quiz-wrong-review" id="wrong-answer-note">
							<h3 style="border-bottom: 2px solid #e5e7eb; padding-bottom: 0.5rem; margin-bottom: 1rem;">📝 오답 노트</h3>
							<div id="wrong-list-container"></div>
						</div>
					</div>
				</div>

				<!-- 하단 퀴즈 네비게이션 -->
				<div class="quiz-nav-section" style="margin-top: 3rem; padding-top: 1.5rem; border-top: 2px solid #e5e7eb;">
					<h3 style="margin-bottom: 1rem; text-align: center; font-size: 1rem; color: #374151;">🎯 다른 회차 풀어보기</h3>
					<div class="quiz-nav-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 0.75rem;">
						{allRanges.filter(r => r.startsWith('q')).map((r) => (
							<a 
								href={`/quiz/${r}`} 
								class={`quiz-nav-item ${r === range ? 'active' : ''}`}
								style={`
									display: block;
									padding: 0.6rem;
									text-align: center;
									background: ${r === range ? '#2563eb' : 'white'};
									color: ${r === range ? 'white' : '#4b5563'};
									border: 1px solid ${r === range ? '#2563eb' : '#e5e7eb'};
									border-radius: 6px;
									text-decoration: none;
									font-size: 0.85rem;
									font-weight: 500;
									transition: all 0.2s;
								`}
							>
								{getDisplayRange(r)}
							</a>
						))}
					</div>
				</div>
			</div>

            <!-- Exit Confirmation Modal (Glassmorphism) -->
            <div id="exit-modal" class="modal-overlay hidden">
                <div class="modal-content glass">
                    <h3>퀴즈를 중단하시겠습니까?</h3>
                    <p>지금까지의 진행 상황이 저장되지 않을 수 있습니다.</p>
                    <div class="modal-buttons">
                        <button id="modal-continue" class="modal-btn secondary">계속 풀기</button>
                        <button id="modal-exit" class="modal-btn primary">나가기</button>
                    </div>
                </div>
            </div>
		</main>
		<Footer />

		<script is:inline define:vars={{ quizData }}>
			document.addEventListener('DOMContentLoaded', () => {
				const gradeButtons = document.querySelectorAll('.grade-btn');
				const showSummaryBtn = document.getElementById('show-summary-btn');
				const userSelections = {};

                // Exit Modal Logic
                const backBtn = document.getElementById('back-to-list');
                const exitModal = document.getElementById('exit-modal');
                const modalContinue = document.getElementById('modal-continue');
                const modalExit = document.getElementById('modal-exit');
                let pendingExitUrl = '';

                const showExitModal = (e, url) => {
                    const hasStarted = Object.keys(userSelections).length > 0;
                    if (hasStarted) {
                        e.preventDefault();
                        pendingExitUrl = url;
                        exitModal?.classList.remove('hidden');
                    }
                };

                backBtn?.addEventListener('click', (e) => showExitModal(e, '/quiz'));
                
                // Intercept Logo and Nav clicks
                document.querySelectorAll('.logo a, .internal-links a').forEach(link => {
                    link.addEventListener('click', (e) => {
                        const href = (link as HTMLAnchorElement).getAttribute('href');
                        if (href) showExitModal(e, href);
                    });
                });

                modalContinue?.addEventListener('click', () => {
                    exitModal?.classList.add('hidden');
                });

                modalExit?.addEventListener('click', () => {
                    window.location.href = pendingExitUrl;
                });

				// 개별 문제 채점
				gradeButtons.forEach(btn => {
					btn.addEventListener('click', () => {
						const quizId = parseInt(btn.dataset.quizId);
						const quizCard = document.getElementById(`quiz-${quizId}`);
						const isMultiple = Array.isArray(JSON.parse(quizCard.dataset.answer));
                        
                        let selectedOptions;
                        if (isMultiple) {
                            selectedOptions = Array.from(quizCard.querySelectorAll(`input[name="q${quizId}"]:checked`)).map(el => parseInt(el.value));
                        } else {
                            const selected = quizCard.querySelector(`input[name="q${quizId}"]:checked`);
                            selectedOptions = selected ? [parseInt(selected.value)] : [];
                        }

						if (selectedOptions.length === 0) {
							alert("답을 선택해 주세요!");
							return;
						}

						userSelections[quizId] = selectedOptions;
                        const correctAnswers = JSON.parse(quizCard.dataset.answer);
                        const correctAnswerList = Array.isArray(correctAnswers) ? correctAnswers : [correctAnswers];

						// UI 업데이트
						const options = quizCard.querySelectorAll('.quiz-option');
						options.forEach((opt, idx) => {
							const input = opt.querySelector('input');
							input.disabled = true;
							opt.classList.add('disabled');

							if (correctAnswerList.includes(idx)) {
								opt.classList.add('correct');
							} else if (selectedOptions.includes(idx)) {
								opt.classList.add('wrong');
							}
						});

						btn.classList.add('hidden');
						document.getElementById(`result-${quizId}`).classList.remove('hidden');
					});
				});

				// 최종 결과 보기
				showSummaryBtn.addEventListener('click', () => {
					let correctCount = 0;
					const wrongListContainer = document.getElementById('wrong-list-container');
					wrongListContainer.innerHTML = '';

					quizData.forEach(quiz => {
						const userChoices = userSelections[quiz.id] || [];
						const correctAnswers = Array.isArray(quiz.answer) ? quiz.answer : [quiz.answer];
						
                        const isCorrect = userChoices.length === correctAnswers.length && 
                                          userChoices.every(choice => correctAnswers.includes(choice));

						if (isCorrect) {
							correctCount++;
						} else {
							const wrongItem = document.createElement('div');
							wrongItem.className = 'quiz-wrong-item';
							
							const userChoiceTexts = userChoices.length > 0 
                                ? userChoices.map(idx => quiz.options[idx]).join(', ') 
                                : "미선택";
							const correctChoiceTexts = correctAnswers.map(idx => quiz.options[idx]).join(', ');

							wrongItem.innerHTML = `
								<div style="margin-bottom: 0.5rem;">
									<span class="quiz-badge" style="background:#ef4444;">Q${quiz.id}</span>
									<strong style="margin-left:0.5rem;">${quiz.question}</strong>
								</div>
								<div style="font-size: 0.9rem; margin-bottom: 0.5rem; padding: 0.5rem; background: #fff1f2; border-radius: 4px;">
									❌ 내 답변: ${userChoiceTexts}
								</div>
								<div style="font-size: 0.9rem; margin-bottom: 0.5rem; padding: 0.5rem; background: #f0fdf4; border-radius: 4px;">
									✅ 정답: ${correctChoiceTexts}
								</div>
								<div style="font-size: 0.85rem; color: #666; border-top: 1px solid #eee; padding-top: 0.5rem;">
									💡 해설: ${quiz.explanation}
								</div>
							`;
							wrongListContainer.appendChild(wrongItem);
						}
					});

					document.getElementById('final-score').textContent = correctCount;
					document.getElementById('summary-result').classList.remove('hidden');
					
					const message = correctCount === quizData.length 
						? "🎉 만점입니다! 완벽해요!" 
						: correctCount >= quizData.length * 0.8 
							? "👍 아주 훌륭한 성적입니다!" 
							: `📖 ${quizData.length}문제 중 ${correctCount}문제를 맞혔습니다. 오답 노트를 확인해 보세요.`;
					document.getElementById('score-message').textContent = message;

					showSummaryBtn.classList.add('hidden');
					
					setTimeout(() => {
						document.getElementById('summary-result').scrollIntoView({ behavior: 'smooth', block: 'start' });
					}, 100);
				});
			});
		</script>
	</body>
</html>
