---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import LoginBenefitCard from '../../components/LoginBenefitCard.astro';
import { allQuizData } from '../../data/all-quiz-data.js';
import { quizSlugMap, quizRangeMap } from '../../lib/utils.js';
import '../../styles/quiz.css';

export function getStaticPaths() {
  return Object.keys(allQuizData).map(range => ({
    params: { slug: quizSlugMap[range] || range }
  }));
}

const { slug } = Astro.params;
const range = quizRangeMap[slug] || slug;
const quizData = allQuizData[range] || [];

// 퀴즈 범위 정보를 기반으로 타이틀 동적 생성
const getDisplayRange = (r) => {
  const parts = r.replace('q', '').split('-');
  if (parts.length === 2) {
    return `${parseInt(parts[0])}~${parseInt(parts[1])}번`;
  }
  return r;
};

const title = `AWS SAA C03 덤프 (${getDisplayRange(range)})`;
const description = `AWS SAA-C03 덤프 문제 ${getDisplayRange(range)}를 인터랙티브하게 풀어보고 오답 노트를 확인하세요.`;

// 전체 퀴즈 목록 (네비게이션용) - 숫자 순서로 정렬
const allRanges = Object.keys(allQuizData).sort((a, b) => {
  const getStart = (s) => parseInt(s.replace('q', '').split('-')[0]);
  return getStart(a) - getStart(b);
});
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<div class="quiz-container">
				<header id="main-quiz-header" class="mobile-hidden" style="text-align: center; margin-bottom: 1.5rem;">
					<h1 style="font-size: 1.5rem; margin-bottom: 0.25rem;">🎯 {title}</h1>
					<p style="color: #666; font-size: 0.85rem;">실제 기출문제를 풀고 실력을 점검해 보세요.</p>
                    <div id="user-greeting" class="hidden" style="margin-top: 1rem; font-size: 0.9rem; color: #1d1d1f; font-weight: 500;">
                        안녕하세요, <span id="user-name"></span>님! 📚
                        <button id="sign-out-btn" style="margin-left: 0.5rem; color: #86868b; background: none; border: none; cursor: pointer; text-decoration: underline; font-size: 0.8rem;">로그아웃</button>
                    </div>
				</header>

				{quizData.length > 0 ? (
                    <div id="quiz-wrapper">
                        <form id="quiz-form">
                            {quizData.map((quiz, index) => (
                                <article class="quiz-card" id={`quiz-${quiz.id}`} data-answer={JSON.stringify(quiz.answer)}>
                                    <div class="quiz-question-header">
                                        <span class="quiz-badge">Q{quiz.id}</span>
                                        <h2 class="quiz-question-text">{quiz.question}</h2>
                                    </div>

                                    <div class="quiz-options">
                                        {quiz.options.map((option, optIndex) => (
                                            <label class="quiz-option" for={`q${quiz.id}-opt${optIndex}`}>
                                                <input 
                                                    type={Array.isArray(quiz.answer) ? "checkbox" : "radio"} 
                                                    name={`q${quiz.id}`} 
                                                    id={`q${quiz.id}-opt${optIndex}`} 
                                                    value={optIndex}
                                                />
                                                <span class="quiz-option-text">{option}</span>
                                            </label>
                                        ))}
                                    </div>

                                    <button type="button" class="quiz-btn grade-btn" data-quiz-id={quiz.id}>
                                        정답 확인 및 해설
                                    </button>

                                    <div class="quiz-result-area hidden" id={`result-${quiz.id}`}>
                                        <div class="quiz-explanation">
                                            <div class="quiz-explanation-title">
                                                <span>📖 해설</span>
                                            </div>
                                            <p class="explanation-text">{quiz.explanation}</p>
                                        </div>

                                        {quiz.glossary && Object.keys(quiz.glossary).length > 0 && (
                                            <div class="quiz-glossary">
                                                <div class="quiz-glossary-title">
                                                    <span>💡 이 문제의 핵심 용어</span>
                                                </div>
                                                <ul class="quiz-glossary-list">
                                                    {Object.entries(quiz.glossary).map(([term, desc]) => (
                                                        <li class="quiz-glossary-item">
                                                            <span class="quiz-glossary-term">{term}</span>: {desc}
                                                        </li>
                                                    ))}
                                                </ul>
                                            </div>
                                        )}
                                    </div>
                                </article>
                            ))}
                        </form>
                    </div>
                ) : (
                    <div style="text-align: center; padding: 4rem; background: white; border-radius: 12px; box-shadow: var(--box-shadow);">
                        <p style="font-size: 1.25rem; color: #666;">데이터를 준비 중입니다. 잠시만 기다려 주세요! 🚧</p>
                    </div>
                )}

				<div class="quiz-summary-card">
					<button id="show-summary-btn" class="quiz-btn" style="background-color: #059669; width: 100%;">
						최종 결과 및 오답 노트 보기
					</button>

					<div id="summary-result" class="hidden">
						<div class="quiz-score-circle">
							<span id="final-score">0</span>
							<span class="quiz-score-text">/ {quizData.length}</span>
						</div>
						<p id="score-message" style="font-weight: 700; font-size: 1.1rem; margin-bottom: 2rem;"></p>
						
						<div class="quiz-wrong-review" id="wrong-answer-note">
							<h3 style="border-bottom: 2px solid #e5e7eb; padding-bottom: 0.5rem; margin-bottom: 1rem;">📝 오답 노트</h3>
							<div id="wrong-list-container"></div>
						</div>

                        <!-- Login Inducement Card at the bottom of results -->
                        <LoginBenefitCard />
					</div>
				</div>

				<!-- 하단 퀴즈 네비게이션 - Hashed Slugs -->
				<div class="quiz-nav-section" style="margin-top: 3rem; padding-top: 1.5rem; border-top: 2px solid #e5e7eb;">
					<h3 style="margin-bottom: 1rem; text-align: center; font-size: 1rem; color: #374151;">🎯 다른 회차 풀어보기</h3>
					<div class="quiz-nav-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 0.75rem;">
						{allRanges.filter(r => r.startsWith('q')).map((r) => (
							<a 
								href={`/quiz/${quizSlugMap[r] || r}`} 
								class={`quiz-nav-item ${r === range ? 'active' : ''}`}
								style={`
									display: block;
									padding: 0.6rem;
									text-align: center;
									background: ${r === range ? '#2563eb' : 'white'};
									color: ${r === range ? 'white' : '#4b5563'};
									border: 1px solid ${r === range ? '#2563eb' : '#e5e7eb'};
									border-radius: 6px;
									text-decoration: none;
									font-size: 0.85rem;
									font-weight: 500;
									transition: all 0.2s;
								`}
							>
								{getDisplayRange(r)}
							</a>
						))}
					</div>
				</div>
			</div>
            <!-- Store quizData for client-side script -->
            <div id="quiz-data-store" data-quiz={JSON.stringify(quizData)} class="hidden"></div>
		</main>
		<Footer />

		<script is:inline>
			// Define sync helper in global scope (simplified for is:inline)
			window.last_visited_quiz = window.location.pathname;
			localStorage.setItem('last_visited_quiz', window.last_visited_quiz);
		</script>

		<script>
			import { supabase } from '../../lib/supabase.js';
			import { signOut } from '../../lib/auth-sync.js';

			document.addEventListener('DOMContentLoaded', async () => {
				const gradeButtons = document.querySelectorAll('.grade-btn');
				const showSummaryBtn = document.getElementById('show-summary-btn');
				const userGreeting = document.getElementById('user-greeting');
				const userName = document.getElementById('user-name');
				const signOutBtn = document.getElementById('sign-out-btn');
                const quizDataStore = document.getElementById('quiz-data-store');
				const userSelections = {};

                if (!quizDataStore) return;
                const quizData = JSON.parse(quizDataStore.dataset.quiz || "[]");

				// Check active session
				console.log('Quiz session check starting...');
				if (supabase) {
					try {
						const { data: { session } } = await supabase.auth.getSession();
						if (session) {
							userGreeting?.classList.remove('hidden');
							if (userName) userName.innerText = session.user.user_metadata.full_name || session.user.email?.split('@')[0];
							
							signOutBtn?.addEventListener('click', async () => {
								await signOut();
							});
						}
					} catch (e) {
						console.error('Supabase session check error:', e);
					}
				} else {
					console.warn('Supabase not initialized. Guest mode active.');
				}

				// Individual question grading
				gradeButtons.forEach(btn => {
					btn.addEventListener('click', async () => {
						const quizId = parseInt(btn.dataset.quizId || "0");
						const quizCard = document.getElementById(`quiz-${quizId}`);
						if (!quizCard) return;

						const isMultiple = Array.isArray(JSON.parse(quizCard.dataset.answer || "[]"));
                        
                        let selectedOptions;
                        if (isMultiple) {
                            selectedOptions = Array.from(quizCard.querySelectorAll(`input[name="q${quizId}"]:checked`)).map(el => parseInt((el as HTMLInputElement).value));
                        } else {
                            const selected = quizCard.querySelector(`input[name="q${quizId}"]:checked`) as HTMLInputElement;
                            selectedOptions = selected ? [parseInt(selected.value)] : [];
                        }

						if (selectedOptions.length === 0) {
							alert("답을 선택해 주세요!");
							return;
						}

						userSelections[quizId] = selectedOptions;
                        const correctAnswers = JSON.parse(quizCard.dataset.answer || "[]");
                        const correctAnswerList = Array.isArray(correctAnswers) ? correctAnswers : [correctAnswers];

						// UI updates
						const options = quizCard.querySelectorAll('.quiz-option');
						options.forEach((opt, idx) => {
							const input = opt.querySelector('input') as HTMLInputElement;
							input.disabled = true;
							opt.classList.add('disabled');

							if (correctAnswerList.includes(idx)) {
								opt.classList.add('correct');
							} else if (selectedOptions.includes(idx)) {
								opt.classList.add('wrong');
							}
						});

						btn.classList.add('hidden');
						document.getElementById(`result-${quizId}`)?.classList.remove('hidden');

                        // Save result
                        const isCorrect = selectedOptions.length === correctAnswerList.length && 
                                          selectedOptions.every(choice => correctAnswerList.includes(choice));

                        if (supabase && (await supabase.auth.getSession()).data.session) {
							const { data: { session } } = await supabase.auth.getSession();
                            await supabase.from('wrong_answers').upsert({
                                user_id: session.user.id,
                                quiz_id: quizId,
                                selected_options: selectedOptions,
                                is_correct: isCorrect
                            });
                        } else if (!isCorrect) {
                            const guestWrongAnswers = JSON.parse(localStorage.getItem('guest_wrong_answers') || '{}');
                            guestWrongAnswers[quizId] = {
                                selected: selectedOptions,
                                date: new Date().toISOString()
                            };
                            localStorage.setItem('guest_wrong_answers', JSON.stringify(guestWrongAnswers));
                        }
					});
				});

				// Final summary
				showSummaryBtn?.addEventListener('click', () => {
					let correctCount = 0;
					const wrongListContainer = document.getElementById('wrong-list-container');
					if (wrongListContainer) wrongListContainer.innerHTML = '';

					quizData.forEach(quiz => {
						const userChoices = userSelections[quiz.id] || [];
						const correctAnswers = Array.isArray(quiz.answer) ? quiz.answer : [quiz.answer];
						
                        const isCorrect = userChoices.length === correctAnswers.length && 
                                          userChoices.every(choice => correctAnswers.includes(choice));

						if (isCorrect) {
							correctCount++;
						} else if (wrongListContainer) {
							const wrongItem = document.createElement('div');
							wrongItem.className = 'quiz-wrong-item';
							
							const userChoiceTexts = userChoices.length > 0 
                                ? userChoices.map(idx => quiz.options[idx]).join(', ') 
                                : "미선택";
							const correctChoiceTexts = correctAnswers.map(idx => quiz.options[idx]).join(', ');

							wrongItem.innerHTML = `
								<div style="margin-bottom: 0.5rem;">
									<span class="quiz-badge" style="background:#ef4444;">Q${quiz.id}</span>
									<strong style="margin-left:0.5rem; word-break:keep-all;">${quiz.question}</strong>
								</div>
								<div style="font-size: 0.9rem; margin-bottom: 0.5rem; padding: 0.6rem; background: #fff1f2; border-radius: 8px; color: #e11d48; word-break:keep-all;">
									❌ 내 답변: ${userChoiceTexts}
								</div>
								<div style="font-size: 0.9rem; margin-bottom: 0.5rem; padding: 0.6rem; background: #f0fdf4; border-radius: 8px; color: #166534; word-break:keep-all;">
									✅ 정답: ${correctChoiceTexts}
								</div>
								<div style="font-size: 0.9rem; color: #3c3c43; border-top: 1px solid #f2f2f7; padding-top: 0.75rem; line-height: 1.6; word-break:keep-all;">
									${quiz.explanation}
								</div>
							`;
							wrongListContainer.appendChild(wrongItem);
						}
					});

                    const finalScoreEl = document.getElementById('final-score');
                    if (finalScoreEl) finalScoreEl.textContent = correctCount.toString();
                    
					document.getElementById('summary-result')?.classList.remove('hidden');
					
					const message = correctCount === quizData.length 
						? "🎉 만점입니다! 완벽해요!" 
						: correctCount >= quizData.length * 0.8 
							? "👍 아주 훌륭한 성적입니다!" 
							: `📖 ${quizData.length}문제 중 ${correctCount}문제를 맞혔습니다. 오답 노트를 확인해 보세요.`;
					
                    const scoreMsgEl = document.getElementById('score-message');
                    if (scoreMsgEl) scoreMsgEl.textContent = message;

					showSummaryBtn.classList.add('hidden');
					
					setTimeout(() => {
						document.getElementById('summary-result')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
					}, 100);
				});
			});
		</script>
	</body>
</html>
