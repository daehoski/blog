---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="footer-links">
			<a href="/">Home</a>
			<a href="/quiz">Quiz</a>
			<a href="/mypage">My Page</a>
			<a href="/about">About</a>
		</div>
		<p class="copyright">&copy; {today.getFullYear()} AWS SAA C03 덤프 마스터. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		padding: 4rem 1.5rem 6rem;
		background: #f5f5f7;
		border-top: 1px solid rgba(0, 0, 0, 0.05);
		text-align: center;
	}
	.footer-content {
		max-width: 980px;
		margin: 0 auto;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		gap: 2rem;
		margin-bottom: 2rem;
	}
	.footer-links a {
		color: #86868b;
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
		transition: color 0.2s;
	}
	.footer-links a:hover {
		color: #1d1d1f;
	}
	.copyright {
		color: #86868b;
		font-size: 0.85rem;
		font-weight: 400;
	}
	@media (max-width: 480px) {
		.footer-links {
			flex-direction: column;
			gap: 1rem;
		}
	}
</style>
