---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="glass">
	<nav>
		<div class="nav-left">
			<h2 class="logo"><a href="/">{SITE_TITLE}</a></h2>
			<div class="internal-links">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/toeic/">TOEIC</HeaderLink>
				<HeaderLink href="/about/">About</HeaderLink>
			</div>
		</div>
		<div class="nav-right">
			<div id="auth-section" class="auth-section">
				<!-- Auth state injected by JS -->
				<button id="header-login-btn" class="login-btn">
					<span class="desktop-text">로그인</span>
					<span class="mobile-icon">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
							<circle cx="12" cy="7" r="4"></circle>
						</svg>
					</span>
				</button>
			</div>
		</div>
	</nav>
</header>

<script>
	import { supabase } from '../lib/supabase';
	import { signInWithGoogle, signOut } from '../lib/auth-sync';

	const authSection = document.getElementById('auth-section');
	const loginBtn = document.getElementById('header-login-btn');

	// Diagnostic Logs
	console.log('Header: Login system initialized.');

	const updateAuthUI = (session) => {
		console.log('Header: Updating Auth UI...', session ? 'Session Active' : 'No Session');
		if (session) {
			const user = session.user;
			const name = user.user_metadata?.full_name || user.email?.split('@')[0] || 'User';
			if (authSection) {
				authSection.innerHTML = `
					<div class="user-info">
						<a href="/mypage/" class="desktop-text user-name-link">${name}님</a>
						<button id="header-logout-btn" class="logout-btn">
							<span class="desktop-text">로그아웃</span>
							<span class="mobile-icon">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
									<polyline points="16 17 21 12 16 7"></polyline>
									<line x1="21" y1="12" x2="9" y2="12"></line>
								</svg>
							</span>
						</button>
					</div>
				`;
			}
		} else {
			if (authSection) {
				authSection.innerHTML = `
					<button id="header-login-btn" class="login-btn">
						<span class="desktop-text">로그인</span>
						<span class="mobile-icon">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
								<circle cx="12" cy="7" r="4"></circle>
							</svg>
						</span>
					</button>
				`;
			}
		}
	};

	// Event Delegation for Auth Buttons (Fixes unresponsiveness)
	authSection?.addEventListener('click', (e) => {
		const target = e.target as HTMLElement;
		const loginBtnCurrent = target.closest('#header-login-btn');
		const logoutBtnCurrent = target.closest('#header-logout-btn');

		if (loginBtnCurrent) {
			console.log('Header: Login button clicked');
			if (!supabase) {
				console.error('Header: Login failed - Supabase client is null. Check PUBLIC_ environment variables.');
				alert('인증 서버가 설정되지 않았습니다.');
				return;
			}
			signInWithGoogle();
		} else if (logoutBtnCurrent) {
			console.log('Header: Logout button clicked');
			signOut();
		}
	});

	// Only attempt auth logic if supabase is available
	if (supabase) {
		console.log('Header: Supabase connected. Checking session...');
		// Initial check
		supabase.auth.getSession().then(({ data: { session } }) => {
			updateAuthUI(session);
		}).catch(err => {
			console.error('Header: Session fetch error:', err);
		});

		// Listen for auth changes
		supabase.auth.onAuthStateChange((_event, session) => {
			console.log('Header: Auth state change detected:', _event);
			updateAuthUI(session);
		});
	} else {
		console.error('Header: Supabase NOT initialized! Auth will NOT work. Verify PUBLIC_SUPABASE_URL.');
	}
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 1000;
		margin: 0;
		padding: 0 1.5rem;
		border-bottom: 1px solid rgba(0, 0, 0, 0.05);
		/* ✅ 유리 효과(Glassmorphism) 복구 */
		background: rgba(255, 255, 255, 0.7);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 64px;
		max-width: 1200px;
		margin: 0 auto;
		gap: 1rem;
	}
	.nav-left {
		display: flex;
		align-items: center;
		gap: 2rem;
	}
	.logo a {
		font-weight: 800;
		letter-spacing: -0.04em;
		font-size: 1.25rem;
		color: #1d1d1f;
		text-decoration: none;
		white-space: nowrap;
	}
	.internal-links {
		display: flex;
		gap: 0.25rem;
	}
	.internal-links :global(a) {
		padding: 0.5rem 0.75rem;
		color: #86868b;
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
		transition: all 0.2s;
		border-radius: 8px;
		white-space: nowrap;
	}
	.internal-links :global(a:hover) {
		color: #1d1d1f;
		background: rgba(0, 0, 0, 0.04);
	}
	.internal-links :global(a.active) {
		color: #1d1d1f;
		font-weight: 700;
	}
	
	/* ✅ JS로 삽입되는 버튼들에 스타일 강제 적용 (:global 사용) */
	:global(.auth-section) {
		display: flex;
		align-items: center;
	}
	:global(.user-info) {
		display: flex;
		align-items: center;
		gap: 0.8rem;
	}
	:global(.user-name-link) {
		color: #1d1d1f;
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 600;
		padding: 0.4rem 0.8rem;
		border-radius: 99px;
		transition: background 0.2s;
	}
	:global(.user-name-link:hover) {
		background: rgba(0, 0, 0, 0.05);
	}

	/* ✅ 로그인/로그아웃 버튼 디자인 (검정색 애플 스타일) */
	:global(.login-btn), :global(.logout-btn) {
		background: #1d1d1f !important;
		border: none !important;
		padding: 0.5rem 1.1rem !important;
		border-radius: 999px !important;
		font-size: 0.85rem !important;
		font-weight: 600 !important;
		color: white !important;
		cursor: pointer;
		transition: all 0.2s;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
	}
	:global(.login-btn:hover), :global(.logout-btn:hover) {
		background: #434345 !important;
		transform: translateY(-1px);
	}

	:global(.mobile-icon) {
		display: none;
	}

	@media (max-width: 768px) {
		header {
			padding: 0 0.5rem;
			height: auto;
		}
		nav {
			flex-direction: column;
			height: auto;
			padding: 0.75rem 0;
			gap: 0.5rem;
		}
		.nav-left {
			flex-direction: column;
			gap: 0.5rem;
			width: 100%;
			align-items: center;
		}
		.logo a {
			font-size: 1.25rem;
		}
		.internal-links {
			justify-content: center;
			width: 100%;
			flex-wrap: wrap;
			gap: 0.2rem;
		}
		.internal-links :global(a) {
			padding: 0.5rem 0.6rem;
			font-size: 0.85rem;
		}
		.nav-right {
			width: 100%;
			justify-content: center;
		}
		:global(.desktop-text) {
			display: none;
		}
		:global(.mobile-icon) {
			display: flex;
		}
		:global(.login-btn), :global(.logout-btn) {
			padding: 0.45rem 1rem !important;
			width: auto;
			height: auto;
			border-radius: 8px !important;
		}
	}
</style>

