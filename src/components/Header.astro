---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="glass">
	<nav>
		<div class="nav-left">
			<h2 class="logo"><a href="/">{SITE_TITLE}</a></h2>
			<div class="internal-links">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/quiz">Quiz</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</div>
		</div>
		<div class="nav-right">
			<div id="auth-section" class="auth-section">
				<!-- Auth state injected by JS -->
				<button id="header-login-btn" class="login-btn">
					<span class="desktop-text">로그인</span>
					<span class="mobile-icon">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
							<circle cx="12" cy="7" r="4"></circle>
						</svg>
					</span>
				</button>
			</div>
		</div>
	</nav>
</header>

<script>
	import { supabase } from '../lib/supabase.js';
	import { signInWithGoogle, signOut } from '../lib/auth-sync.js';

	const authSection = document.getElementById('auth-section');
	const loginBtn = document.getElementById('header-login-btn');

	const updateAuthUI = (session) => {
		if (session) {
			const user = session.user;
			const name = user.user_metadata?.full_name || user.email?.split('@')[0] || 'User';
			authSection.innerHTML = `
				<div class="user-info">
					<span class="desktop-text">${name}님</span>
					<button id="header-logout-btn" class="logout-btn">
						<span class="desktop-text">로그아웃</span>
						<span class="mobile-icon">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
								<polyline points="16 17 21 12 16 7"></polyline>
								<line x1="21" y1="12" x2="9" y2="12"></line>
							</svg>
						</span>
					</button>
				</div>
			`;
			document.getElementById('header-logout-btn')?.addEventListener('click', () => signOut());
		} else {
			authSection.innerHTML = `
				<button id="header-login-btn" class="login-btn">
					<span class="desktop-text">로그인</span>
					<span class="mobile-icon">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
							<circle cx="12" cy="7" r="4"></circle>
						</svg>
					</span>
				</button>
			`;
			document.getElementById('header-login-btn')?.addEventListener('click', () => signInWithGoogle());
		}
	};

	// Initial check
	supabase.auth.getSession().then(({ data: { session } }) => {
		updateAuthUI(session);
	});

	// Listen for auth changes
	supabase.auth.onAuthStateChange((_event, session) => {
		updateAuthUI(session);
	});
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 1000;
		margin: 0;
		padding: 0 1.5rem;
		border-bottom: 1px solid rgba(0, 0, 0, 0.05);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 64px;
		max-width: 1200px;
		margin: 0 auto;
		gap: 1rem;
	}
	.nav-left {
		display: flex;
		align-items: center;
		gap: 2rem;
	}
	.logo a {
		font-weight: 800;
		letter-spacing: -0.04em;
		font-size: 1.25rem;
		color: #1d1d1f;
		text-decoration: none;
		white-space: nowrap;
	}
	.internal-links {
		display: flex;
		gap: 0.25rem;
	}
	.internal-links :global(a) {
		padding: 0.5rem 0.75rem;
		color: #86868b;
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
		transition: all 0.2s;
		border-radius: 8px;
		white-space: nowrap;
	}
	.internal-links :global(a:hover) {
		color: #1d1d1f;
		background: rgba(0, 0, 0, 0.04);
	}
	.internal-links :global(a.active) {
		color: #1d1d1f;
		font-weight: 700;
	}
	
	.auth-section {
		display: flex;
		align-items: center;
	}
	.user-info {
		display: flex;
		align-items: center;
		gap: 1rem;
		color: #1d1d1f;
		font-size: 0.9rem;
		font-weight: 600;
	}
	.login-btn, .logout-btn {
		background: transparent;
		border: 1px solid rgba(0, 0, 0, 0.1);
		padding: 0.4rem 1rem;
		border-radius: 999px;
		font-size: 0.85rem;
		font-weight: 600;
		color: #1d1d1f;
		cursor: pointer;
		transition: all 0.2s;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.login-btn:hover, .logout-btn:hover {
		background: rgba(0, 0, 0, 0.04);
		border-color: rgba(0, 0, 0, 0.2);
	}

	.mobile-icon {
		display: none;
	}

	@media (max-width: 768px) {
		header {
			padding: 0 1rem;
		}
		.nav-left {
			gap: 0.5rem;
		}
		.internal-links {
			gap: 0;
		}
		.internal-links :global(a) {
			padding: 0.4rem 0.5rem;
			font-size: 0.8rem;
		}
		.desktop-text {
			display: none;
		}
		.mobile-icon {
			display: flex;
		}
		.login-btn, .logout-btn {
			padding: 0.5rem;
			border: none;
		}
	}

	@media (max-width: 480px) {
		.logo a {
			font-size: 1.1rem;
		}
		.internal-links :global(a) {
			padding: 0.4rem 0.4rem;
		}
	}
</style>

